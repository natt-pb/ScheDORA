<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.classroomscheduler.controller.DashboardController" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" stylesheets="@../css/style.css">
    <VBox styleClass="main-canvas" spacing="24">
        <!-- Page Header -->
        <VBox spacing="4">
            <Label fx:id="welcomeLabel" text="Welcome back, User" styleClass="page-title"/>
            <Label text="Classroom Relocation and Booking Management Portal Overview" styleClass="page-subtitle"/>
        </VBox>
        
        <!-- Bento Metrics Grid -->
        <GridPane hgap="20" vgap="20">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
            </columnConstraints>
            
            <!-- Card 1: Total Classrooms -->
            <VBox GridPane.columnIndex="0" styleClass="glass-panel" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <StackPane style="-fx-background-color: rgba(185, 0, 12, 0.1); -fx-background-radius: 8px; -fx-padding: 8;">
                        <Label text="🚪" style="-fx-font-size: 18px; -fx-text-fill: -theme-primary;"/>
                    </StackPane>
                </HBox>
                <VBox spacing="2">
                    <Label text="TOTAL CLASSROOMS" styleClass="filter-label" style="-fx-font-size: 11px;"/>
                    <Label fx:id="lblTotalRooms" text="8" styleClass="page-title" style="-fx-font-size: 32px; -fx-padding: 0;"/>
                </VBox>
                <Separator/>
                <Label text="Available on campus" styleClass="schedule-card-info"/>
            </VBox>
            
            <!-- Card 2: Pending Requests -->
            <VBox GridPane.columnIndex="1" styleClass="glass-panel" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <StackPane style="-fx-background-color: rgba(115, 86, 0, 0.1); -fx-background-radius: 8px; -fx-padding: 8;">
                        <Label text="⏳" style="-fx-font-size: 18px;"/>
                    </StackPane>
                </HBox>
                <VBox spacing="2">
                    <Label text="PENDING APPROVALS" styleClass="filter-label" style="-fx-font-size: 11px;"/>
                    <Label fx:id="lblPendingBookings" text="2" styleClass="page-title" style="-fx-font-size: 32px; -fx-padding: 0;"/>
                </VBox>
                <Separator/>
                <Label text="Require Admin Action" styleClass="schedule-card-info"/>
            </VBox>
            
            <!-- Card 3: Active Bookings -->
            <VBox GridPane.columnIndex="2" styleClass="glass-panel" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <StackPane style="-fx-background-color: rgba(45, 88, 191, 0.1); -fx-background-radius: 8px; -fx-padding: 8;">
                        <Label text="✓" style="-fx-font-size: 18px;"/>
                    </StackPane>
                </HBox>
                <VBox spacing="2">
                    <Label text="APPROVED BOOKINGS" styleClass="filter-label" style="-fx-font-size: 11px;"/>
                    <Label fx:id="lblApprovedBookings" text="1" styleClass="page-title" style="-fx-font-size: 32px; -fx-padding: 0;"/>
                </VBox>
                <Separator/>
                <Label text="Allocated in this semester" styleClass="schedule-card-info"/>
            </VBox>
            
            <!-- Card 4: Utilization Rate -->
            <VBox GridPane.columnIndex="3" styleClass="glass-panel" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <StackPane style="-fx-background-color: rgba(46, 125, 50, 0.1); -fx-background-radius: 8px; -fx-padding: 8;">
                        <Label text="📊" style="-fx-font-size: 18px;"/>
                    </StackPane>
                </HBox>
                <VBox spacing="2">
                    <Label text="ROOM UTILIZATION" styleClass="filter-label" style="-fx-font-size: 11px;"/>
                    <Label text="75%" styleClass="page-title" style="-fx-font-size: 32px; -fx-padding: 0;"/>
                </VBox>
                <ProgressBar progress="0.75" styleClass="stats-progress-bar" maxWidth="Infinity"/>
            </VBox>
        </GridPane>
        
        <!-- Main Dashboard Split Content -->
        <GridPane hgap="24" vgap="20">
            <columnConstraints>
                <ColumnConstraints percentWidth="60"/>
                <ColumnConstraints percentWidth="40"/>
            </columnConstraints>
            
            <!-- Left: Upcoming Booking Schedules -->
            <VBox GridPane.columnIndex="0" styleClass="glass-panel" spacing="16">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Active Relocations &amp; Bookings" styleClass="stats-title" style="-fx-font-size: 18px;"/>
                </HBox>
                
                <TableView fx:id="tblUpcoming" prefHeight="280">
                    <columns>
                        <TableColumn fx:id="colCourse" text="Course" prefWidth="100"/>
                        <TableColumn fx:id="colRoom" text="Room" prefWidth="90"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                        <TableColumn fx:id="colTime" text="Time Slot" prefWidth="120"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>
            
            <!-- Right: Quick Actions and System Help -->
            <VBox GridPane.columnIndex="1" spacing="20">
                <VBox styleClass="glass-panel" spacing="16">
                    <Label text="Quick Help Center" styleClass="stats-title" style="-fx-font-size: 16px;"/>
                    <VBox spacing="12">
                        <VBox spacing="4" style="-fx-background-color: -theme-surface-low; -fx-padding: 10; -fx-background-radius: 8px;">
                            <Label text="🚨 Classroom Unavailable?" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <Label text="Check the current timetable, then use the Availability Search to find open rooms." styleClass="schedule-card-info" style="-fx-font-size: 11px;" wrapText="true"/>
                        </VBox>
                        <VBox spacing="4" style="-fx-background-color: -theme-surface-low; -fx-padding: 10; -fx-background-radius: 8px;">
                            <Label text="🔒 Request Approvals" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <Label text="Booking replacements require administrator verification. Approved slots will appear in the schedule." styleClass="schedule-card-info" style="-fx-font-size: 11px;" wrapText="true"/>
                        </VBox>
                    </VBox>
                </VBox>
            </VBox>
        </GridPane>
    </VBox>
</ScrollPane>
