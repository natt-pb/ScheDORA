<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.classroomscheduler.controller.ChangePasswordController"
      styleClass="login-root" stylesheets="@../css/style.css">

    <VBox alignment="CENTER" spacing="16" maxWidth="400" styleClass="card">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="🔒 Change Your Password" styleClass="section-title"/>
        <Label fx:id="lblWelcome" text="Please set a new password to continue." styleClass="info-label"
               wrapText="true" textAlignment="CENTER"/>

        <VBox spacing="8">
            <Label text="New Password" styleClass="form-label"/>
            <PasswordField fx:id="txtNewPassword" promptText="Enter new password" styleClass="text-input"/>
        </VBox>

        <VBox spacing="8">
            <Label text="Confirm Password" styleClass="form-label"/>
            <PasswordField fx:id="txtConfirmPassword" promptText="Confirm new password" styleClass="text-input"/>
        </VBox>

        <Button text="Set Password &amp; Continue" onAction="#handleChangePassword"
                styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>
</VBox>
